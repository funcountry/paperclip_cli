agent_list() {
  local tree="0"
  local rows
  local row_count

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --tree)
        tree="1"
        ;;
      -h|--help)
        agent_usage
        return 0
        ;;
      *)
        fail "Unknown option: $1"
        ;;
