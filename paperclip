  resolve_agent_target "$agent_ref"

  scope_rows="$(query_agent_scope "$include_reports")"
  scope_count="$(count_lines "$scope_rows")"

  log "Target: $TARGET_AGENT_NAME"
  log "Thinking level: $thinking_level"
  if [[ "$include_reports" == "1" ]]; then
    log "Scope: self and reports ($scope_count agents)"
  else
    log "Scope: self only"
  fi
  print_agent_scope "$scope_rows"

  if [[ "$dry_run" == "1" ]]; then
    log "Dry run only. No changes applied."
    return 0
  fi

  updated_rows="$(update_agent_thinking_level "$thinking_level" "$include_reports")"
  updated_count="$(count_lines "$updated_rows")"

  if [[ "$updated_count" == "0" ]]; then
    fail "No agents were updated"
  fi

  log "Updated $updated_count agent(s):"
  while IFS=$'\t' read -r id name role adapter_type reasoning_effort; do
    [[ -n "$id" ]] || continue
    printf '  - %s adapter=%s thinking=%s\n' "$name" "$adapter_type" "${reasoning_effort:-<unset>}"
  done <<<"$updated_rows"
}

run_agent_command() {
  local topic="${1:-}"
  local action="${2:-}"

  case "$topic" in
    list)
      shift 1
      agent_list "$@"
      ;;
    heartbeat)
      case "$action" in
        set)
          shift 2
          agent_heartbeat_set "$@"
          ;;
        ""|-h|--help)
          agent_usage
          ;;
        *)
          fail "Unknown agent heartbeat command: $action"
          ;;
      esac
      ;;
    thinking)
      case "$action" in
        set)
          shift 2
          agent_thinking_set "$@"
          ;;
        ""|-h|--help)
          agent_usage
          ;;
        *)
          fail "Unknown agent thinking command: $action"
          ;;
      esac
      ;;
    ""|-h|--help)
      agent_usage
      ;;
    *)
      fail "Unknown agent command: $topic"
      ;;
  esac
}

cmd="${1:-}"
case "$cmd" in
  start)
    start_daemon
    ;;
  stop)
    stop_daemon
    ;;
  status)
    show_status
    ;;
  doctor)
    doctor
    ;;
  agent|agents)
    shift
    run_agent_command "$@"
    ;;
  *)
    usage
    exit 1
    ;;
esac
