    lower(a.name) || ':' || a.id::text as sort_key
  from agents a
  where a.reports_to is null
     or not exists (
       select 1
       from agents parent
       where parent.id = a.reports_to
         and parent.company_id = a.company_id
     )

  union all

  select
    a.id,
    a.company_id,
    a.name,
    a.role,
    a.status,
    a.adapter_type,
    coalesce(nullif(a.adapter_config->>'model', ''), '-') as model,
    coalesce(nullif(a.adapter_config->>'modelReasoningEffort', ''), '-') as reasoning_effort,
    coalesce(nullif(a.runtime_config->'heartbeat'->>'intervalSec', ''), '-') as heartbeat_interval_sec,
    org.depth + 1 as depth,
    org.sort_key || '/' || lower(a.name) || ':' || a.id::text as sort_key
  from agents a
  join org on a.reports_to = org.id and a.company_id = org.company_id
)
select
  id,
  name,
  role,
  status,
  adapter_type,
  model,
  reasoning_effort,
  heartbeat_interval_sec,
  depth,
  company_id::text
from org
