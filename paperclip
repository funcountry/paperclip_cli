agent_heartbeat_set() {
  local agent_ref="${1:-}"
  local interval_raw="${2:-}"
  local interval_sec
  local include_reports="1"
  local dry_run="0"
  local scope_mode="self-and-reports"
  local scope_mode_explicit="0"
  local scope_rows
  local scope_count
  local updated_rows
  local updated_count
  local id
  local name
  local role
  local adapter_type
  local current_interval
  local heartbeat_enabled

  [[ -n "$agent_ref" ]] || {
    agent_usage
    fail "Missing agent name or id"
  }
  [[ -n "$interval_raw" ]] || {
    agent_usage
    fail "Missing heartbeat interval"
  }

  shift 2
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --self)
        if [[ "$scope_mode" == "self-and-reports" && "$scope_mode_explicit" == "1" ]]; then
          fail "Use either --self or --self-and-reports, not both"
        fi
        include_reports="0"
        scope_mode="self"
        scope_mode_explicit="1"
        ;;
      --self-and-reports|--include-reports)
        if [[ "$scope_mode" == "self" && "$scope_mode_explicit" == "1" ]]; then
          fail "Use either --self or --self-and-reports, not both"
        fi
        include_reports="1"
        scope_mode="self-and-reports"
        scope_mode_explicit="1"
        ;;
      --dry-run)
        dry_run="1"
        ;;
      -h|--help)
        agent_usage
        return 0
        ;;
      *)
        fail "Unknown option: $1"
        ;;
    esac
    shift
  done

  interval_sec="$(normalize_heartbeat_interval "$interval_raw")"
  require_running_instance
  resolve_agent_target "$agent_ref"

  scope_rows="$(query_agent_heartbeat_scope "$include_reports")"
  scope_count="$(count_lines "$scope_rows")"

  log "Target: $TARGET_AGENT_NAME"
  log "Heartbeat interval: $(format_interval_label "$interval_sec")"
  if [[ "$include_reports" == "1" ]]; then
    log "Scope: self and reports ($scope_count agents)"
  else
    log "Scope: self only"
  fi
  print_agent_heartbeat_scope "$scope_rows"

  if [[ "$dry_run" == "1" ]]; then
    log "Dry run only. No changes applied."
    return 0
  fi

  updated_rows="$(update_agent_heartbeat_interval "$interval_sec" "$include_reports")"
  updated_count="$(count_lines "$updated_rows")"

  if [[ "$updated_count" == "0" ]]; then
    fail "No agents were updated"
  fi

  log "Updated $updated_count agent(s):"
  while IFS=$'\t' read -r id name role adapter_type current_interval heartbeat_enabled; do
    [[ -n "$id" ]] || continue
    printf '  - %s adapter=%s heartbeat=%s enabled=%s\n' \
      "$name" \
      "$adapter_type" \
      "$(format_interval_label "$current_interval")" \
      "$(display_value "$heartbeat_enabled")"
  done <<<"$updated_rows"
}

